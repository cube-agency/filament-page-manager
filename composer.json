{
    "name": "cube-agency/filament-page-manager",
    "description": "Page manager for Filament",
    "keywords": [
        "cube-agency",
        "laravel",
        "filament-page-manager"
    ],
    "homepage": "https://github.com/cube-agency/filament-page-manager",
    "support": {
        "issues": "https://github.com/cube-agency/filament-page-manager/issues",
        "source": "https://github.com/cube-agency/filament-page-manager"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Dmitrijs Mihailovs",
            "email": "dmitrijs.mihailovs@cube.lv",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "cube-agency/filament-tree-view": "^3.0",
        "cube-agency/filament-json": "^3.0",
        "cube-agency/filament-template": "^3.0",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0|^9.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "CubeAgency\\FilamentPageManager\\": "src/",
            "CubeAgency\\FilamentPageManager\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CubeAgency\\FilamentPageManager\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CubeAgency\\FilamentPageManager\\FilamentPageManagerServiceProvider"
            ],
            "aliases": {
                "FilamentPageManager": "CubeAgency\\FilamentPageManager\\Facades\\FilamentPageManager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
